# Celonis MCP Server Configuration (used by local dev + setup script)
# SECURITY NOTE: This sample stores secrets in plaintext for simplicity in this
# educational sample. In production, store secrets in AWS Secrets Manager and reference
# them by ARN. Ensure .env is in .gitignore and never committed to source control.
CELONIS_MCP_SERVER_URL=https://YOUR_TEAM.YOUR_REALM.celonis.cloud/studio-copilot/api/v1/mcp-servers/mcp/YOUR_MCP_SERVER_ID
CELONIS_TOKEN_URL=https://YOUR_TEAM.YOUR_REALM.celonis.cloud/oauth2/token
CELONIS_CLIENT_ID=your-celonis-client-id
CELONIS_CLIENT_SECRET=your-celonis-client-secret
CELONIS_OAUTH_SCOPE=mcp-asset.tools:execute

# AWS Configuration
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1

# AgentCore Gateway (populated by setupAWSbackend.py)
GATEWAY_URL=
GATEWAY_ID=

# AgentCore Runtime (populated after agentcore launch)
AGENTCORE_AGENT_ID=

# Cognito (populated by setupAWSbackend.py — used for inbound JWT auth)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_TOKEN_URL=
COGNITO_SCOPE=
